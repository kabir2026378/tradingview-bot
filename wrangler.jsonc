{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tradingview-bot",
  "main": "src/index.js",
  "compatibility_date": "2026-06-20",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "vars": {
    "SECURITY_KEY": "my-coinbase-passphrase"
  }
}
